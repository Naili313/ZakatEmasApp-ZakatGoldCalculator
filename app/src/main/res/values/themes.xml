<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ZakatGoldCalculator" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
    </style>

    <style name="Theme.ZakatGoldCalculator" parent="Base.Theme.ZakatGoldCalculator" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.ZakatGoldCalculator</item>
    </style>
</resources>